# Astro emits content-hashed, immutable assets (CSS, JS, optimized images,
# self-hosted fonts) under /_astro/ — safe to cache for a year.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static favicon/icons
/favicon.svg
  Cache-Control: public, max-age=604800
/favicon.ico
  Cache-Control: public, max-age=604800

# HTML pages — short cache so updates are seen quickly
/
  Cache-Control: public, max-age=3600, must-revalidate
/*.html
  Cache-Control: public, max-age=3600, must-revalidate
